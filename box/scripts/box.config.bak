#!/system/bin/sh

bin_name="mihomo"
redir_port="7891"
tproxy_port="1536"
clash_dns_port="1053"
clash_dns_listen="0.0.0.0:${clash_dns_port}"
mihome_dns_forward="true"
fake_ip_range_v4="198.18.0.0/15"
fake_ip_range_v6="fc00::/18"
tun_device="tun0"
box_user_group="root:net_admin"
# 如果要更改用户或组，必须将 Box 核心放置在 /system/bin 目录中，否则更改不会生效。
# 如果使用 Magisk，可以将 Box 核心文件（sing-box、clash 等）复制到 /data/adb/modules/bin_files/system/bin/ 并重启手机
bin_name_list=("sing-box" "clash" "mihomo" "xray" "v2ray" "hysteria")
box_path="/data/adb/box"
bin_path="${box_path}/bin/${bin_name}"
run_path="${box_path}/run"
pid_file="${run_path}/${bin_name}.pid"
intranet=(0.0.0.0/8 10.0.0.0/8 100.0.0.0/8 127.0.0.0/8 169.254.0.0/16 192.0.0.0/24 192.0.2.0/24 192.88.99.0/24 192.168.0.0/16 198.51.100.0/24 203.0.113.0/24 224.0.0.0/4 240.0.0.0/4 255.255.255.255/32)
# 使用 100.0.0.0/8 而不是 100.64.0.0/10 完全是由于中国电信运营商的失误，你可以将其改回
intranet6=(::/128 ::1/128 ::ffff:0:0/96 100::/64 64:ff9b::/96 2001::/32 2001:10::/28 2001:20::/28 2001:db8::/32 2002::/16 fe80::/10 ff00::/8)
ipv6="disable"
proxy_method="TPROXY"
# REDIRECT：仅 TCP / TPROXY：TCP + UDP / MIXED：REDIRECT TCP + TUN UDP
proxy_mode="blacklist"
# 黑名单 / 白名单 / 核心
user_packages_list=()
# Android 用户:包名，例如：
# user_packages_list=("0:com.android.captiveportallogin" "10:com.tencent.mm")
gid_list=()
# 列表中的 gid 将根据 proxy_mode 配置被绕过或代理，gid 可以通过 busybox setuidgid 命令任意指定
ap_list=("wlan+" "ap+" "rndis+" "ncm+")
ignore_out_list=()
ipv6="enable"
clash_api_port=9090
# clash api 端口
clash_api_secret=
# clash api 密钥
use_custom_direct=false
# 真 / 假
ctr_mode=disable
# 禁用 / 切换 / 选择器 / 模式
select_outbound=domestic
# 需要为代理切换选择类型策略组
default_outbound=direct
# 移动网络下的默认代理
direct_outbound=direct
# WLAN 下的代理
proxy_outbound=
# 固定移动网络下的代理
direct_outbound_list=""
# 与 direct_outbound 相同。SSID,代理，例如：
# CMCC_XXXX,DIRECT;TPLINK_XXXX,ROUTER
default_clash_mode=direct
direct_clash_mode=rule
# 连接 WLAN 时的 Clash 模式
proxy_clash_mode=
# 断开 WLAN 时的 Clash 模式
direct_clash_mode_list=""
# 与 direct_mode 相同。SSID,ClashMode，例如：
# CMCC_XXXX,rule;TPLINK_XXXX,rule-tplink
